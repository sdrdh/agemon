{
  "name": "agemon",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "bun run --filter '@agemon/backend' dev & bun run --filter '@agemon/frontend' dev & wait",
    "build": "bun run --filter '*' build",
    "clean": "rm -rf backend/dist frontend/dist node_modules"
  }
}
